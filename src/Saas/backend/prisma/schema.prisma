generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("SAAS_DATABASE_URL")
}

model SaasRequest {
  id        String   @id
  tenantId  String
  userId    String
  action    String
  resource  String
  status    String   @default("pending")
  payload   Json?
  result    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("saas_requests")
  @@index([tenantId, resource])
}
