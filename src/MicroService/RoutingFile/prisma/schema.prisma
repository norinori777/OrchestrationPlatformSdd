generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("ROUTING_DATABASE_URL")
}

model RoutingRequest {
  id             String    @id
  filePath       String
  originalName   String
  mimeType       String
  size           Int?
  status         String    @default("pending")   // pending | processing | completed | failed
  category       String?
  confidence     Float?
  reason         String?
  model          String?
  promptVersion  String?
  errorMessage   String?
  chunkResults   Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@map("routing_requests")
  @@index([status])
  @@index([category])
}
