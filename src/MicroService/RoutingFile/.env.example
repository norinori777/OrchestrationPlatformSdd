# PostgreSQL接続URL (routing-file-service専用DB)
ROUTING_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/routing_file_db?schema=public"

# OpenAI APIキー
OPENAI_API_KEY="sk-..."

# 使用するOpenAIモデル (省略時: gpt-4o-mini)
OPENAI_MODEL="gpt-4o-mini"

# サービスポート (省略時: 4003)
PORT=4003

# チャンクあたりの最大トークン数 (省略時: 2000)
MAX_CHUNK_TOKENS=2000

# ファイルあたりの最大チャンク数 (省略時: 10)
MAX_CHUNKS_PER_FILE=10
